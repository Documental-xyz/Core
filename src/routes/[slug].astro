---
import PageLayout from '../layouts/pages/PageLayout.astro';
import { PAGES_COLLECTION } from '../lib/collections';

const { slug } = Astro.params;

export async function getStaticPaths() {
  const { getCollection } = await import('astro:content');
  const pages = await getCollection(PAGES_COLLECTION);

  return pages
    .filter((page) => {
      const s = page.data.standalone;
      // undefined = no field at all (old pages) → render (backward compat)
      // null = user unchecked in CMS → don't render
      // { enabled: false } = explicit false → don't render
      // { enabled: true } or { enabled: null/undefined } = render
      if (s === undefined) return true;
      if (s === null) return false;
      return s.enabled !== false;
    })
    .map((page) => ({
      params: { slug: page.id },
    }));
}
---

<PageLayout slug={slug} />
